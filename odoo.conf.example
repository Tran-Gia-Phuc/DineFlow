[options]
; ==========================================
; DineFlow - Odoo 17 Configuration (EXAMPLE)
; Copy file này thành odoo.conf và điền password thật
; File odoo.conf đã được .gitignore - KHÔNG commit
; ==========================================

addons_path = /mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons

; Database
db_host = db
db_port = 5432
db_user = odoo
db_password = YOUR_DB_PASSWORD_HERE
db_name = odoo

; Server
http_port = 8069
longpolling_port = 8072

; Performance (tối ưu cho 16GB RAM)
workers = 4
max_cron_threads = 2
limit_memory_hard = 2684354560
limit_memory_soft = 2147483648
limit_time_cpu = 60
limit_time_real = 120

; Dev / Debug
dev_mode = True

; Logging
log_level = info

; Admin
admin_passwd = YOUR_MASTER_PASSWORD_HERE
