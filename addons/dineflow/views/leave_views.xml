<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_restaurant_leave_tree" model="ir.ui.view">
        <field name="name">restaurant.leave.request.tree</field>
        <field name="model">restaurant.leave.request</field>
        <field name="arch" type="xml">
            <tree string="Xin nghỉ phép">
                <field name="employee_id" />
                <field name="leave_type" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="reason" />
                <field name="status" widget="badge"
                    decoration-info="status == 'draft'"
                    decoration-warning="status == 'confirmed'"
                    decoration-success="status == 'approved'"
                    decoration-danger="status == 'refused'" />
                <field name="created_by_ai" widget="boolean_toggle" />
                <button name="%(dineflow.action_approve_leave_wizard)d" type="action"
                    string="Duyệt hàng loạt" class="btn-primary"
                    groups="dineflow.group_dineflow_manager"
                    context="{'default_leave_ids': active_ids}" />
            </tree>
        </field>
    </record>

    <record id="view_restaurant_leave_form" model="ir.ui.view">
        <field name="name">restaurant.leave.request.form</field>
        <field name="model">restaurant.leave.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Duyệt" type="object"
                        class="btn-primary"
                        groups="dineflow.group_dineflow_manager" />
                    <button name="action_refuse" string="Từ chối" type="object"
                        class="btn-danger"
                        groups="dineflow.group_dineflow_manager" />
                    <field name="status" widget="statusbar"
                        statusbar_visible="draft,confirmed,approved" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" />
                            <field name="leave_type" />
                            <field name="created_by_ai" />
                        </group>
                        <group>
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="manager_id" />
                            <field name="approved_date" />
                        </group>
                    </group>
                    <field name="reason" placeholder="Lý do xin nghỉ..." />
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_leave" model="ir.actions.act_window">
        <field name="name">Xin nghỉ phép</field>
        <field name="res_model">restaurant.leave.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_restaurant_leave"
        name="Xin nghỉ phép"
        parent="menu_dineflow_hr"
        action="action_restaurant_leave"
        sequence="20" />

</odoo>