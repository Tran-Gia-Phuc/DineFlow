<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_table_form" model="ir.ui.view">
        <field name="name">restaurant.table.form</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <form string="Bàn nhà hàng">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="floor" />
                            <field name="capacity" />
                            <field name="min_capacity" />
                        </group>
                        <group>
                            <field name="status" widget="radio" />
                            <field name="active" />
                            <field name="qr_code" />
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú về bàn..." />
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_restaurant_table_tree" model="ir.ui.view">
        <field name="name">restaurant.table.tree</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <tree string="Danh sách bàn">
                <field name="name" string="Tên bàn" />
                <field name="floor" string="Khu vực" />
                <field name="capacity" string="Sức chứa" width="150" optional="show" />
                <field name="status" widget="badge"
                    decoration-success="status == 'available'"
                    decoration-warning="status == 'reserved'"
                    decoration-danger="status == 'occupied'" />
                <field name="active" string="Hoạt động" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_restaurant_table_kanban" model="ir.ui.view">
        <field name="name">restaurant.table.kanban</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name" />
                <field name="capacity" />
                <field name="floor" />
                <field name="status" />
                <templates>
                    <t t-name="card">
                        <div class="p-2">
                            <strong>
                                <field name="name" />
                            </strong>
                            <div class="text-muted">Khu: <field name="floor" /></div>
                            <div>Sức chứa: <field name="capacity" /> người</div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_restaurant_table" model="ir.actions.act_window">
        <field name="name">Bàn nhà hàng</field>
        <field name="res_model">restaurant.table</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_restaurant_table"
        name="Danh sách bàn"
        parent="menu_dineflow_table"
        action="action_restaurant_table"
        sequence="10" />

</odoo>