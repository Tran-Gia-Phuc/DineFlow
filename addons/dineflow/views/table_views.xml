<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_restaurant_table_form" model="ir.ui.view">
        <field name="name">restaurant.table.form</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <form string="Bàn nhà hàng">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="floor" />
                            <field name="capacity" />
                            <field name="min_capacity" />
                        </group>
                        <group>
                            <field name="status" widget="radio" />
                            <field name="active" />
                            <field name="qr_code" />
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú về bàn..." />
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_restaurant_table_tree" model="ir.ui.view">
        <field name="name">restaurant.table.tree</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <tree string="Bàn"
                decoration-success="status == 'available'"
                decoration-warning="status == 'reserved'"
                decoration-danger="status == 'occupied'">
                <field name="name" string="Tên bàn" />
                <field name="floor" string="Khu vực" />
                <field name="capacity" string="Sức chứa tối đa" />
                <field name="min_capacity" string="Tối thiểu" optional="hide" />
                <field name="status" widget="badge"
                    decoration-success="status == 'available'"
                    decoration-warning="status == 'reserved'"
                    decoration-danger="status == 'occupied'" />
                <field name="current_guest" string="Khách hiện tại" />
                <field name="current_time_start" string="Giờ đến" widget="datetime" />
                <field name="current_time_end" string="Giờ kết thúc" widget="datetime" />
                <field name="next_booking_time" string="Đặt tiếp theo" widget="datetime"
                    optional="hide" />
                <field name="note" string="Ghi chú" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_restaurant_table_form" model="ir.ui.view">
        <field name="name">restaurant.table.form</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="floor" />
                            <field name="status" widget="badge" />
                            <field name="active" />
                        </group>
                        <group>
                            <field name="capacity" />
                            <field name="min_capacity" />
                            <field name="qr_code" optional="hide" />
                        </group>
                    </group>

                    <!-- Thông tin booking đang chiếm bàn -->
                    <group string="Đang sử dụng"
                        invisible="not current_booking_id">
                        <field name="current_booking_id" string="Mã đặt bàn" readonly="1" />
                        <field name="current_guest" string="Khách" readonly="1" />
                        <field name="current_time_start" string="Giờ đến" readonly="1" />
                        <field name="current_time_end" string="Giờ kết thúc" readonly="1" />
                    </group>

                    <!-- Booking tiếp theo -->
                    <group string="Lượt tiếp theo"
                        invisible="not next_booking_id">
                        <field name="next_booking_id" string="Mã đặt bàn" readonly="1" />
                        <field name="next_booking_time" string="Giờ đến" readonly="1" />
                    </group>

                    <field name="note" placeholder="Ghi chú về bàn..." />

                    <notebook>
                        <page string="Lịch đặt bàn">
                            <field name="booking_ids" readonly="1">
                                <tree decoration-muted="status in ('cancelled','done')"
                                    decoration-info="status == 'pending'"
                                    decoration-success="status == 'confirmed'">
                                    <field name="name" />
                                    <field name="customer_name" />
                                    <field name="date_start" />
                                    <field name="date_end" />
                                    <field name="guest_count" />
                                    <field name="status" widget="badge" />
                                </tree>
                            </field>
                        </page>
                        <page string="Order">
                            <field name="order_ids" readonly="1">
                                <tree>
                                    <field name="name" />
                                    <field name="waiter_id" />
                                    <field name="total_amount" />
                                    <field name="status" widget="badge" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_restaurant_table_kanban" model="ir.ui.view">
        <field name="name">restaurant.table.kanban</field>
        <field name="model">restaurant.table</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name" />
                <field name="capacity" />
                <field name="floor" />
                <field name="status" />
                <templates>
                    <t t-name="card">
                        <div class="p-2">
                            <strong>
                                <field name="name" />
                            </strong>
                            <div class="text-muted">Khu: <field name="floor" /></div>
                            <div>Sức chứa: <field name="capacity" /> người</div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_restaurant_table" model="ir.actions.act_window">
        <field name="name">Bàn nhà hàng</field>
        <field name="res_model">restaurant.table</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_restaurant_table"
        name="Danh sách bàn"
        parent="menu_dineflow_table"
        action="action_restaurant_table"
        sequence="10" />

</odoo>