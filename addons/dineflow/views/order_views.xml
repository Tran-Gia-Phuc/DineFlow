<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_restaurant_order_tree" model="ir.ui.view">
        <field name="name">restaurant.order.tree</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <tree string="Order">
                <field name="name" />
                <field name="table_id" />
                <field name="waiter_id" />
                <field name="total_amount" />
                <field name="payment_method" />
                <field name="status" widget="badge"
                    decoration-info="status == 'open'"
                    decoration-success="status == 'paid'"
                    decoration-danger="status == 'cancelled'" />
            </tree>
        </field>
    </record>

    <record id="view_restaurant_order_form" model="ir.ui.view">
        <field name="name">restaurant.order.form</field>
        <field name="model">restaurant.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(dineflow.action_payment_wizard)d" type="action"
                        string="Thanh toán" class="btn-primary"
                        invisible="status != 'open'"
                        context="{'default_order_id': active_id}" />
                    <button name="%(dineflow.action_cancel_order_wizard)d" type="action"
                        string="Huỷ order" class="btn-danger"
                        invisible="status != 'open'"
                        groups="dineflow.group_dineflow_manager,dineflow.group_dineflow_cashier"
                        context="{'default_order_id': active_id}" />
                    <field name="status" widget="statusbar"
                        statusbar_visible="open,paid" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1" />
                            <field name="table_id" />
                            <field name="booking_id" />
                        </group>
                        <group>
                            <field name="waiter_id" />
                            <field name="payment_method" />
                            <field name="total_amount" readonly="1" />
                        </group>
                    </group>
                    <field name="order_line_ids">
                        <tree editable="bottom">
                            <field name="menu_item_id" />
                            <field name="unit_price" />
                            <field name="quantity" />
                            <field name="subtotal" readonly="1" />
                            <field name="note" />
                        </tree>
                    </field>
                    <field name="note" placeholder="Ghi chú order..." />
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_restaurant_order" model="ir.actions.act_window">
        <field name="name">Order</field>
        <field name="res_model">restaurant.order</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_restaurant_order"
        name="Danh sách order"
        parent="menu_dineflow_order"
        action="action_restaurant_order"
        sequence="10" />

</odoo>