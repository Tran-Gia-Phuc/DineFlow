<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_dineflow_form" model="ir.ui.view">
        <field name="name">hr.employee.dineflow.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page name="restaurant_info" string="Thông tin nhà hàng">
                    <group>
                        <field name="restaurant_role"/>
                        <field name="employee_code"/>
                        <field name="shift"/>
                        <field name="pin_code"/>
                    </group>
                    <field name="leave_request_ids" readonly="1">
                        <tree>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="leave_type"/>
                            <field name="status"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_dineflow_employee" model="ir.actions.act_window">
        <field name="name">Nhân viên</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="groups_id" eval="[(6, 0, [ref('dineflow.group_dineflow_manager')])]"/>
    </record>

    <menuitem id="menu_dineflow_employee"
        name="Nhân viên"
        parent="menu_dineflow_hr"
        action="action_dineflow_employee"
        sequence="10"
        groups="dineflow.group_dineflow_manager"/>

</odoo>