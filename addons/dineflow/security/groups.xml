    </record>

    <record id="group_dineflow_waiter" model="res.groups">
        <field name="name">Phục vụ</field>
        <field name="category_id" ref="module_category_dineflow"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_dineflow_chef" model="res.groups">
        <field name="name">Đầu bếp</field>
        <field name="category_id" ref="module_category_dineflow"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
