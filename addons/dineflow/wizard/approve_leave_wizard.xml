<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approve_leave_wizard_form" model="ir.ui.view">
        <field name="name">restaurant.approve.leave.wizard.form</field>
        <field name="model">restaurant.approve.leave.wizard</field>
        <field name="arch" type="xml">
            <form string="Duyệt đơn nghỉ phép">
                <group>
                    <field name="manager_id"/>
                    <field name="note"/>
                </group>
                <field name="leave_ids">
                    <tree>
                        <field name="employee_id"/>
                        <field name="leave_type"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="reason"/>
                        <field name="status"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_approve_all" string="Duyệt tất cả"
                        type="object" class="btn-primary"/>
                    <button name="action_refuse_all" string="Từ chối tất cả"
                        type="object" class="btn-danger"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_approve_leave_wizard" model="ir.actions.act_window">
        <field name="name">Duyệt nghỉ phép hàng loạt</field>
        <field name="res_model">restaurant.approve.leave.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>